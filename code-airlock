#!/usr/bin/env bash
# code-airlock — run coding agents unattended in a Docker Sandbox (microVM),
# with git-observable output and a locked-down network.
#
# The agent runs inside a disposable microVM with a hard hypervisor boundary
# from your host. In clone mode it commits to a private clone; your repo is
# mounted read-only and you review its work with a normal `git fetch`.
#
# Repo: https://github.com/Trivo25/code-airlock   License: MIT

set -euo pipefail

# ---- config -----------------------------------------------------------------
# Defaults below can be overridden in ./sandbox.conf or via environment vars.
CONF="$(cd "$(dirname "$0")" && pwd)/sandbox.conf"
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"

: "${AGENT:=claude}"                     # claude, codex, opencode, gemini, copilot, cursor, droid, kiro, shell
REPO_DIR="${REPO_DIR:-$PWD}"             # repo the agent works on
: "${GLOBAL_NETWORK_POLICY:=balanced}"   # allow-all, balanced, deny-all
: "${REVIEW_TOOL:=vscode}"               # git difftool name, e.g. vscode, opendiff, vimdiff
: "${DRY_RUN:=0}"                        # 1 prints commands without running them
: "${USE_TMUX:=0}"                       # 1 runs `up` inside a host tmux session
: "${TMUX_ATTACH:=1}"                    # 1 attaches after starting a tmux-backed `up`
: "${SEED_CONFIG:=0}"                    # 1 seeds curated user-level agent config
: "${SEED_USER_CONFIG:=$SEED_CONFIG}"    # 1 copies user-level commands/agents/skills/instructions
: "${SEED_PATHS:=}"                      # comma-separated extra host paths to copy under /home/user
: "${FETCH_SUBMODULES:=1}"               # 1 imports initialized submodule commits from the sandbox on fetch

# Sandbox name derived from the repo folder, sanitized to a safe token.
_repo_base="$(basename "$REPO_DIR")"
_default_name="sbx-${_repo_base//[^a-zA-Z0-9._-]/-}"
NAME="${SANDBOX_NAME:-$_default_name}"
TMUX_SESSION="${TMUX_SESSION:-code-airlock-$NAME}"

# Hosts the sandbox may reach. Everything else is blocked once you run
# `lockdown` (or if your default sbx policy is already balanced/deny-all).
DEFAULT_ALLOW="api.anthropic.com,*.anthropic.com,api.openai.com,*.openai.com,github.com,*.github.com,codeload.github.com,objects.githubusercontent.com,registry.npmjs.org,*.npmjs.org"
ALLOW="${ALLOW:-$DEFAULT_ALLOW}"

# ---- helpers ----------------------------------------------------------------
_c()  { printf '\033[%sm%s\033[0m\n' "$1" "$2"; }
info() { _c 36 "$*"; }
warn() { _c 33 "$*" >&2; }
err()  { _c 31 "$*" >&2; }
die()  { err "$*"; exit 1; }

need() { command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }

print_cmd() {
  printf '+'
  printf ' %q' "$@"
  printf '\n'
}

quote_words() {
  for word in "$@"; do
    printf ' %q' "$word"
  done
}

quote_env() {
  name="$1"
  value="$2"
  printf '%s=%q' "$name" "$value"
}

run_cmd() {
  if [ "$DRY_RUN" = 1 ]; then
    print_cmd "$@"
  else
    "$@"
  fi
}

run_sbx() {
  run_cmd sbx "$@"
}

doctor_ok() { printf '\033[32mOK\033[0m   %s\n' "$*"; }
doctor_warn() { printf '\033[33mWARN\033[0m %s\n' "$*"; DOCTOR_WARNS=$((DOCTOR_WARNS + 1)); }
doctor_fail() { printf '\033[31mFAIL\033[0m %s\n' "$*"; DOCTOR_FAILS=$((DOCTOR_FAILS + 1)); }

preflight() {
  [ "$DRY_RUN" = 1 ] && return 0
  need sbx
  need git
  if [ "$(uname -s)" = "Linux" ] && ! lsmod 2>/dev/null | grep -q kvm; then
    warn "KVM not detected. Docker Sandboxes needs hardware virtualization on Linux."
  fi
}

is_git_repo() { git -C "$REPO_DIR" rev-parse --git-dir >/dev/null 2>&1; }

ensure_repo() {
  is_git_repo && return 0
  warn "No git repository found in $REPO_DIR."
  printf 'Initialize one now (needed for clone mode)? [y/N] '
  read -r ans
  [ "${ans:-}" = y ] || die "Aborting: clone mode requires a git repo."
  git -C "$REPO_DIR" init -q
  git -C "$REPO_DIR" add -A
  git -C "$REPO_DIR" commit -qm "chore: initial commit" --allow-empty
  info "Initialized a git repo with an initial commit."
}

running() { sbx exec "$NAME" true >/dev/null 2>&1; }

seed_path_is_safe() {
  case "$1" in
    */auth.json|*/auth.*|*credentials*|*credential*|*token*|*/sessions|*/sessions/*|*/logs|*/logs/*|*/history*|*.log|*/cache|*/cache/*|*/node_modules|*/node_modules/*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

seed_copy() {
  src="$1"
  dest_dir="$2"

  if ! seed_path_is_safe "$src"; then
    warn "Skipping potentially sensitive config path: $src"
    return 0
  fi

  if [ "$DRY_RUN" != 1 ] && [ ! -e "$src" ]; then
    return 0
  fi

  info "Seeding config: $src -> $NAME:$dest_dir"
  run_sbx exec "$NAME" mkdir -p "$dest_dir"
  run_sbx cp "$src" "$NAME:$dest_dir"
}

seed_extra_paths() {
  [ -n "$SEED_PATHS" ] || return 0

  old_ifs="$IFS"
  IFS=,
  # shellcheck disable=SC2206
  paths=($SEED_PATHS)
  IFS="$old_ifs"

  for src in "${paths[@]}"; do
    [ -n "$src" ] || continue
    case "$src" in
      "$HOME"/*)
        rel="${src#"$HOME"/}"
        dest_dir="/home/user/$(dirname "$rel")"
        seed_copy "$src" "$dest_dir"
        ;;
      *)
        warn "Skipping SEED_PATHS entry outside HOME: $src"
        ;;
    esac
  done
}

seed_user_config() {
  [ "$SEED_USER_CONFIG" = 1 ] || [ -n "$SEED_PATHS" ] || return 0

  info "Seeding user-level agent config into '$NAME'."
  case "$AGENT" in
    claude)
      if [ "$SEED_USER_CONFIG" = 1 ]; then
        seed_copy "$HOME/.claude/CLAUDE.md" "/home/user/.claude"
        seed_copy "$HOME/.claude/commands" "/home/user/.claude"
        seed_copy "$HOME/.claude/agents" "/home/user/.claude"
        seed_copy "$HOME/.claude/skills" "/home/user/.claude"
      fi
      ;;
    codex)
      if [ "$SEED_USER_CONFIG" = 1 ]; then
        seed_copy "$HOME/.codex/AGENTS.md" "/home/user/.codex"
        seed_copy "$HOME/.codex/AGENT.md" "/home/user/.codex"
        seed_copy "$HOME/.codex/agents" "/home/user/.codex"
        seed_copy "$HOME/.codex/skills" "/home/user/.codex"
        seed_copy "$HOME/.codex/prompts" "/home/user/.codex"
      fi
      ;;
    opencode)
      if [ "$SEED_USER_CONFIG" = 1 ]; then
        seed_copy "$HOME/.config/opencode/AGENTS.md" "/home/user/.config/opencode"
        seed_copy "$HOME/.config/opencode/opencode.jsonc" "/home/user/.config/opencode"
        seed_copy "$HOME/.config/opencode/commands" "/home/user/.config/opencode"
        seed_copy "$HOME/.config/opencode/agents" "/home/user/.config/opencode"
        seed_copy "$HOME/.config/opencode/skills" "/home/user/.config/opencode"
      fi
      ;;
    *)
      [ "$SEED_USER_CONFIG" = 1 ] && warn "No default user-config seed allowlist for agent '$AGENT'. Use SEED_PATHS for explicit paths."
      ;;
  esac

  seed_extra_paths
}

tmux_session_exists() {
  tmux has-session -t "$TMUX_SESSION" 2>/dev/null
}

kill_tmux_session() {
  if [ "$DRY_RUN" = 1 ]; then
    print_cmd tmux has-session -t "$TMUX_SESSION"
    print_cmd tmux kill-session -t "$TMUX_SESSION"
    return 0
  fi

  command -v tmux >/dev/null 2>&1 || return 0
  tmux_session_exists || return 0
  info "Removing tmux session '$TMUX_SESSION'."
  tmux kill-session -t "$TMUX_SESSION"
}

init_global_network_policy() {
  info "Initializing Docker Sandboxes global network policy if needed: $GLOBAL_NETWORK_POLICY"
  if [ "$DRY_RUN" = 1 ]; then
    run_sbx policy init "$GLOBAL_NETWORK_POLICY"
    return 0
  fi

  if policy_output="$(sbx policy init "$GLOBAL_NETWORK_POLICY" 2>&1)"; then
    return 0
  fi

  case "$policy_output" in
    *"already"*|*"initialized"*)
      return 0
      ;;
    *)
      printf '%s\n' "$policy_output" >&2
      die "Could not initialize Docker Sandboxes network policy."
      ;;
  esac
}

apply_network() {
  info "Restricting network for '$NAME' to: $ALLOW"
  if run_sbx policy allow network --sandbox "$NAME" "$ALLOW"; then
    return 0
  fi

  warn "Could not apply network rules. Make sure sandbox '$NAME' exists, then check: sbx policy ls"
  return 1
}

current_branch() {
  git -C "$REPO_DIR" symbolic-ref --short HEAD 2>/dev/null || echo main
}

sandbox_ref() {
  printf 'sandbox-%s/%s' "$NAME" "${1:-$(current_branch)}"
}

fetch_sandbox() {
  run_cmd git -C "$REPO_DIR" fetch "sandbox-$NAME"
  fetch_sandbox_submodules
}

submodule_paths() {
  # The snippet runs inside `git submodule foreach`, where Git sets $displaypath.
  # shellcheck disable=SC2016
  git -C "$REPO_DIR" submodule foreach --recursive --quiet 'printf "%s\n" "$displaypath"' 2>/dev/null || true
}

safe_token() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '-'
}

fetch_sandbox_submodules() {
  [ "$FETCH_SUBMODULES" = 1 ] || return 0
  [ -f "$REPO_DIR/.gitmodules" ] || return 0

  submodule_path_list="$(submodule_paths)"
  if [ -z "$submodule_path_list" ]; then
    warn "Submodules are configured, but none are initialized locally. Run: git submodule update --init --recursive"
    return 0
  fi

  tmpdir="${TMPDIR:-/tmp}/code-airlock-submodules-$NAME-$$"
  info "Fetching sandbox submodule commits into initialized host submodules."
  run_cmd mkdir -p "$tmpdir"

  while IFS= read -r sm_path; do
    [ -n "$sm_path" ] || continue

    if [ "$DRY_RUN" != 1 ] && ! git -C "$REPO_DIR/$sm_path" rev-parse --git-dir >/dev/null 2>&1; then
      warn "Skipping uninitialized submodule: $sm_path"
      continue
    fi

    safe_path="$(safe_token "$sm_path")"
    sandbox_bundle="/tmp/code-airlock-$safe_path.bundle"
    host_bundle="$tmpdir/$safe_path.bundle"
    remote_ref="refs/remotes/code-airlock/$NAME"

    info "Fetching submodule '$sm_path' from sandbox into $remote_ref"
    if ! run_sbx exec "$NAME" sh -lc "git -C $(printf '%q' "$sm_path") bundle create $(printf '%q' "$sandbox_bundle") HEAD >/dev/null"; then
      warn "Could not create sandbox bundle for submodule '$sm_path'. Is the sandbox still available?"
      continue
    fi
    if ! run_sbx cp "$NAME:$sandbox_bundle" "$host_bundle"; then
      warn "Could not copy sandbox bundle for submodule '$sm_path'."
      continue
    fi
    if ! run_cmd git -C "$REPO_DIR/$sm_path" fetch "$host_bundle" "HEAD:$remote_ref"; then
      warn "Could not fetch sandbox bundle into host submodule '$sm_path'."
      continue
    fi
  done <<EOF
$submodule_path_list
EOF
}

agents_file() {
  printf '%s/AGENTS.md' "$REPO_DIR"
}

write_agents_file() {
  path="$(agents_file)"
  [ -e "$path" ] && die "AGENTS.md already exists in $REPO_DIR"

  cat >"$path" <<'EOF'
# Agent Instructions

This repository may be worked on by sandboxed coding agents through Code Airlock.

## Working Rules

- Inspect the repo before editing. Follow existing structure, style, and tooling.
- Keep changes small, reviewable, and focused on the requested task.
- Do not add dependencies, push to remotes, publish releases, or touch credentials unless explicitly asked.
- Prefer fixing root causes over broad rewrites.
- Commit finished work inside the sandbox so the host can fetch, diff, and merge it.

## Verification

- Run the most relevant tests, linters, formatters, or build checks for the change.
- If a check cannot be run, explain why in the final response.
- Report changed files and any known risks before stopping.
EOF
}

hint_agents_file() {
  [ -e "$(agents_file)" ] && return 0
  info "No AGENTS.md found in the target repo. Run '$0 init' to add starter agent instructions."
}

agent_hint() {
  case "$AGENT" in
    claude)
      info "Claude auth: interactive /login in the sandbox, or store a key with: sbx secret set -g anthropic"
      ;;
    codex)
      info "Codex auth: run 'sbx secret set -g openai --oauth' or 'sbx secret set -g openai' before headless runs."
      ;;
    opencode)
      info "OpenCode auth: store provider keys with sbx secret, e.g. openai, anthropic, google, xai, groq, aws, or openrouter."
      ;;
  esac
}

first_run_note() {
  # one-time note after the first completed run or merge; never repeats
  [ "$DRY_RUN" = 1 ] && return 0
  state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/code-airlock"
  marker="$state_dir/first-run-note"
  [ -e "$marker" ] && return 0
  mkdir -p "$state_dir" 2>/dev/null || return 0
  : >"$marker" 2>/dev/null || return 0
  printf '\n'
  info "Code Airlock completed its first reviewed run."
  info "If it was useful, star the project: https://github.com/Trivo25/code-airlock"
}

# ---- commands ---------------------------------------------------------------
cmd_up_tmux() {
  [ "$DRY_RUN" = 1 ] || need tmux
  session="$TMUX_SESSION"
  tmux_shell="${SHELL:-/bin/sh}"
  script_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  inner_cmd="$(quote_env AGENT "$AGENT") $(quote_env REPO_DIR "$REPO_DIR") $(quote_env SANDBOX_NAME "$NAME") $(quote_env GLOBAL_NETWORK_POLICY "$GLOBAL_NETWORK_POLICY") $(quote_env REVIEW_TOOL "$REVIEW_TOOL") $(quote_env TMUX_SESSION "$TMUX_SESSION") $(quote_env ALLOW "$ALLOW") $(quote_env SEED_CONFIG "$SEED_CONFIG") $(quote_env SEED_USER_CONFIG "$SEED_USER_CONFIG") $(quote_env SEED_PATHS "$SEED_PATHS") $(printf '%q' "$script_path") up$(quote_words "$@")"

  if [ "$DRY_RUN" != 1 ] && tmux has-session -t "$session" 2>/dev/null; then
    die "tmux session '$session' already exists. Attach with: tmux attach -t $session"
  fi

  info "Starting Code Airlock in tmux session '$session'."
  info "Detach without stopping the agent: Ctrl-b, then d"
  [ "$TMUX_ATTACH" = 1 ] || info "Attach later with: $0 attach"
  run_cmd tmux new-session -d -s "$session" -c "$REPO_DIR" "$tmux_shell"
  run_cmd tmux send-keys -t "$session" "$inner_cmd" C-m
  if [ "$DRY_RUN" != 1 ]; then
    sleep 1
    tmux has-session -t "$session" 2>/dev/null || die "tmux session '$session' exited immediately. Inspect tmux/server output with: tmux list-sessions"
  fi
  if [ "$TMUX_ATTACH" = 1 ]; then
    attach_tmux_session "$session"
  fi
}

attach_tmux_session() {
  session="${1:-$TMUX_SESSION}"
  if [ -n "${TMUX:-}" ]; then
    run_cmd tmux switch-client -t "$session"
  else
    run_cmd tmux attach -t "$session"
  fi
}

cmd_attach() {
  [ "$DRY_RUN" = 1 ] || need tmux
  if [ "$DRY_RUN" != 1 ] && ! tmux_session_exists; then
    die "tmux session '$TMUX_SESSION' not found. Start one with: $0 --tmux up"
  fi

  attach_tmux_session "$TMUX_SESSION"
}

cmd_up() {
  if [ "$USE_TMUX" = 1 ]; then
    cmd_up_tmux "$@"
    return 0
  fi

  preflight
  cd "$REPO_DIR"
  if [ "$DRY_RUN" != 1 ]; then
    ensure_repo
    running && die "Sandbox '$NAME' already exists. Use '$0 shell', or '$0 rm' to recreate."
  fi

  hint_agents_file
  init_global_network_policy
  if [ "$DRY_RUN" = 1 ]; then
    info "Would start $AGENT in a microVM sandbox '$NAME' (clone mode)."
  else
    info "Starting $AGENT in a microVM sandbox '$NAME' (clone mode)."
  fi
  info "Review its commits on your host with:  git fetch sandbox-$NAME"
  agent_hint
  warn "Full network isolation applies only under a balanced/deny-all default."
  warn "For strict isolation after the sandbox exists, run:  $0 lockdown"
  info "First launch may take a few minutes while Docker creates the VM and prepares the agent kit."

  # --clone: agent works on a private clone; host repo mounted read-only.
  # Docker Sandboxes applies each agent's own startup defaults.
  # Any extra args after the command are passed through to the agent, e.g.:
  #   ./code-airlock up -- -p "refactor the auth module and run the tests"
  if [ "$SEED_USER_CONFIG" = 1 ] || [ -n "$SEED_PATHS" ]; then
    run_sbx create --clone --name "$NAME" "$AGENT" "$REPO_DIR"
    seed_user_config
    if [ "$#" -gt 0 ]; then
      run_sbx run --name "$NAME" "$AGENT" "$@"
    else
      run_sbx run --name "$NAME" "$AGENT"
    fi
    return 0
  fi

  if [ "$#" -gt 0 ]; then
    run_sbx run --clone --name "$NAME" "$AGENT" "$@"
  else
    run_sbx run --clone --name "$NAME" "$AGENT"
  fi
}

cmd_run() {
  task="${1:-}"
  [ -n "$task" ] || die "Usage: $(basename "$0") run \"<task>\""
  shift

  # translate the task into the agent's non-interactive invocation
  case "$AGENT" in
    claude)   set -- -p "$task" "$@" ;;
    codex)    set -- exec --dangerously-bypass-approvals-and-sandbox "$task" "$@" ;;
    opencode) set -- run "$task" "$@" ;;
    *)
      warn "No headless mapping for agent '$AGENT'; passing the task as a plain argument."
      set -- "$task" "$@"
      ;;
  esac

  cmd_up "$@"

  if [ "$DRY_RUN" != 1 ] && [ "$USE_TMUX" != 1 ]; then
    info "Agent run finished. Review the result:"
    info "  $0 diff     # inspect the changes"
    info "  $0 review   # open a visual review"
    info "  $0 merge    # merge into your branch"
    first_run_note
  fi
}

cmd_shell() { preflight; run_sbx exec -it "$NAME" bash; }

cmd_init() {
  [ -d "$REPO_DIR" ] || die "Repo directory does not exist: $REPO_DIR"
  if [ "$DRY_RUN" = 1 ]; then
    info "Dry run only. Would create $(agents_file)"
    return 0
  fi

  write_agents_file
  info "Created $(agents_file)"
}

cmd_fetch() { preflight; fetch_sandbox; }

cmd_diff() {
  preflight
  base="${1:-$(current_branch)}"
  fetch_sandbox
  run_cmd git -C "$REPO_DIR" diff "$base..$(sandbox_ref "$base")"
}

cmd_review() {
  preflight
  base="${1:-$(current_branch)}"
  fetch_sandbox

  ref="$(sandbox_ref "$base")"
  if [ "$DRY_RUN" != 1 ]; then
    git -C "$REPO_DIR" rev-parse --verify "$ref" >/dev/null \
      || die "Sandbox branch not found: $ref"
  fi

  info "Opening visual review with git difftool: $REVIEW_TOOL"
  run_cmd git -C "$REPO_DIR" difftool --dir-diff --no-prompt --tool="$REVIEW_TOOL" "$base" "$ref"
}

cmd_merge() {
  preflight
  base="${1:-$(current_branch)}"
  fetch_sandbox
  info "Merging sandbox-$NAME/$base into $base"
  run_cmd git -C "$REPO_DIR" merge "$(sandbox_ref "$base")"
  first_run_note
}

cmd_pr() {
  preflight
  base="${1:-$(current_branch)}"
  branch="${2:-${PR_BRANCH:-code-airlock/$NAME}}"
  fetch_sandbox

  ref="$(sandbox_ref "$base")"
  if [ "$DRY_RUN" != 1 ]; then
    git -C "$REPO_DIR" rev-parse --verify "$ref" >/dev/null \
      || die "Sandbox branch not found: $ref"
    git -C "$REPO_DIR" remote get-url origin >/dev/null 2>&1 \
      || die "No 'origin' remote configured. Add one, then rerun: $0 pr"
  fi

  # host-side push: the sandbox never needs GitHub credentials for this
  info "Updating branch '$branch' from $ref and pushing to origin."
  run_cmd git -C "$REPO_DIR" branch -f "$branch" "$ref"
  run_cmd git -C "$REPO_DIR" push -u origin "$branch"

  if command -v gh >/dev/null 2>&1; then
    if [ "$DRY_RUN" = 1 ]; then
      print_cmd gh pr create --head "$branch" --base "$base" --fill
      return 0
    fi
    info "Opening a pull request: $branch -> $base"
    (cd "$REPO_DIR" && gh pr create --head "$branch" --base "$base" --fill)
    return 0
  fi

  warn "gh is not installed. The branch is pushed; open the pull request manually."
  origin_url="$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || true)"
  case "$origin_url" in
    git@github.com:*) repo_path="${origin_url#git@github.com:}" ;;
    https://github.com/*) repo_path="${origin_url#https://github.com/}" ;;
    *) repo_path="" ;;
  esac
  [ -n "$repo_path" ] && info "  https://github.com/${repo_path%.git}/compare/$base...$branch"
}

cmd_net()  { preflight; run_sbx policy log; }

cmd_stop() {
  preflight
  run_sbx stop "$NAME"
  if [ "$DRY_RUN" = 1 ]; then
    info "Dry run only. '$NAME' was not stopped."
  else
    info "Stopped '$NAME'. Its VM and commits are preserved."
  fi
}

cmd_status() {
  DOCTOR_FAILS=0
  DOCTOR_WARNS=0

  info "Code Airlock status for: $REPO_DIR"
  printf 'Sandbox: %s\n' "$NAME"
  printf 'tmux:    %s\n' "$TMUX_SESSION"

  if [ "$DRY_RUN" = 1 ]; then
    print_cmd sbx exec "$NAME" true
    print_cmd sbx ls
    print_cmd tmux has-session -t "$TMUX_SESSION"
    print_cmd tmux display-message -p -t "$TMUX_SESSION" '#{session_attached}'
    return 0
  fi

  if command -v sbx >/dev/null 2>&1; then
    if running; then
      doctor_ok "sandbox '$NAME' is running"
    elif sbx_list="$(sbx ls 2>/dev/null)" && printf '%s\n' "$sbx_list" | grep -F "$NAME" >/dev/null; then
      doctor_warn "sandbox '$NAME' exists but is not running/reachable"
    else
      doctor_warn "sandbox '$NAME' not found"
    fi
  else
    doctor_fail "sbx is not installed"
  fi

  if command -v tmux >/dev/null 2>&1; then
    if tmux_session_exists; then
      attached="$(tmux display-message -p -t "$TMUX_SESSION" '#{session_attached}' 2>/dev/null || echo '?')"
      if [ "$attached" = 0 ]; then
        doctor_ok "tmux session '$TMUX_SESSION' is active and detached"
      else
        doctor_ok "tmux session '$TMUX_SESSION' is active; attached clients: $attached"
      fi
    else
      doctor_warn "tmux session '$TMUX_SESSION' not found"
    fi
  else
    doctor_warn "tmux is not installed"
  fi
}

cmd_rm() {
  preflight
  warn "Removing '$NAME' deletes its clone and this repo's tmux session. Unfetched or unpushed commits are lost."
  if [ "$DRY_RUN" = 1 ]; then
    print_cmd git -C "$REPO_DIR" fetch "sandbox-$NAME"
    kill_tmux_session
    run_sbx rm "$NAME"
    return 0
  fi

  printf 'Fetch its commits first? [Y/n] '
  read -r ans
  [ "${ans:-}" = n ] || git -C "$REPO_DIR" fetch "sandbox-$NAME" 2>/dev/null || true
  kill_tmux_session
  sbx rm "$NAME"
}

cmd_lockdown() {
  preflight
  info "Setting the default network policy to deny-all for all sandboxes."
  info "Revert at any time with:  sbx policy reset"
  run_sbx policy set-default deny-all
  if apply_network; then
    if [ "$DRY_RUN" = 1 ]; then
      info "Dry run only. No network policy was changed."
    else
      info "Locked down. '$NAME' may reach only the allowlist above."
    fi
  else
    warn "Global deny-all policy is set, but the per-sandbox allowlist was not applied."
  fi
}

cmd_unlock() {
  preflight
  info "Resetting Docker Sandboxes policies to defaults."
  run_sbx policy reset
  [ "$DRY_RUN" = 1 ] && info "Dry run only. No network policy was reset."
}

setup_step() {
  # show the exact command, then ask before running it
  desc="$1"
  shift
  printf '\n'
  info "$desc"
  print_cmd "$@"
  [ "$DRY_RUN" = 1 ] && return 0
  printf 'Run it now? [y/N] '
  read -r ans
  if [ "${ans:-}" != y ]; then
    warn "Skipped. Run it manually when ready."
    return 0
  fi
  "$@" || warn "Command failed (exit $?). Fix the problem above, then rerun: $0 setup"
}

cmd_setup() {
  DOCTOR_FAILS=0
  DOCTOR_WARNS=0
  os="$(uname -s)"

  info "Guided setup for Code Airlock prerequisites ($os)."
  info "Each step shows the exact command and asks before running anything."

  # git
  if command -v git >/dev/null 2>&1; then
    doctor_ok "git installed"
  else
    case "$os" in
      Darwin) setup_step "git is missing. Install the Apple command line tools:" xcode-select --install ;;
      Linux)
        if command -v apt-get >/dev/null 2>&1; then
          setup_step "git is missing. Install it:" sudo apt-get install -y git
        else
          warn "git is missing. Install it with your distribution's package manager."
        fi
        ;;
      *) warn "git is missing. Install it first: https://git-scm.com/downloads" ;;
    esac
  fi

  # Docker Sandboxes CLI
  if command -v sbx >/dev/null 2>&1; then
    doctor_ok "sbx installed"
  else
    case "$os" in
      Linux)
        if command -v apt-get >/dev/null 2>&1; then
          info "Docker Sandboxes is missing. It installs from Docker's repository in three steps."
          setup_step "1/3 Add Docker's package repository:" sh -c 'curl -fsSL https://get.docker.com | sudo REPO_ONLY=1 sh'
          setup_step "2/3 Install Docker Sandboxes:" sudo apt-get install -y docker-sbx
          setup_step "3/3 Let your user access KVM (log out and back in afterwards):" sudo usermod -aG kvm "$USER"
        else
          warn "Docker Sandboxes is missing. Follow the install guide for your distribution:"
          info "  https://docs.docker.com/ai/sandboxes/get-started/"
        fi
        ;;
      Darwin)
        warn "Docker Sandboxes is missing. On macOS (Apple Silicon), install it via Docker's guide:"
        info "  https://docs.docker.com/ai/sandboxes/get-started/"
        ;;
      MINGW*|MSYS*|CYGWIN*)
        warn "Run Code Airlock inside WSL2 on Windows 11 with Hypervisor Platform enabled."
        info "  https://docs.docker.com/ai/sandboxes/get-started/"
        ;;
      *)
        warn "Unsupported host OS: $os. Docker Sandboxes supports macOS, Linux, and Windows via WSL2."
        ;;
    esac
  fi

  # authentication
  if command -v sbx >/dev/null 2>&1 && ! sbx ls >/dev/null 2>&1; then
    setup_step "The sbx CLI is not authenticated yet:" sbx login
  fi

  printf '\n'
  info "Setup finished. Validate the environment with:  $0 doctor"
}

cmd_doctor() {
  DOCTOR_FAILS=0
  DOCTOR_WARNS=0

  info "Checking Code Airlock prerequisites..."

  if command -v sbx >/dev/null 2>&1; then
    version="$(sbx version 2>/dev/null || true)"
    doctor_ok "sbx installed${version:+ ($version)}"
  else
    doctor_fail "sbx is not installed. Install Docker Sandboxes first."
  fi

  if command -v git >/dev/null 2>&1; then
    doctor_ok "git installed ($(git --version))"
  else
    doctor_fail "git is not installed. Clone mode and review commands require git."
  fi

  case "$(uname -s)" in
    Linux)
      if [ -e /dev/kvm ] || { command -v lsmod >/dev/null 2>&1 && lsmod 2>/dev/null | grep -q kvm; }; then
        doctor_ok "KVM virtualization available"
      else
        doctor_fail "KVM virtualization not detected. Enable hardware virtualization and ensure /dev/kvm is available."
      fi
      ;;
    Darwin)
      if [ "$(uname -m)" = arm64 ]; then
        doctor_ok "Apple Silicon host detected"
      elif [ "$(sysctl -n kern.hv_support 2>/dev/null || echo 0)" = 1 ]; then
        doctor_ok "macOS Hypervisor framework available"
      else
        doctor_fail "macOS virtualization support not detected."
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      doctor_warn "Windows virtualization was not checked. Docker Sandboxes requires Windows 11 with Hypervisor Platform under WSL2."
      ;;
    *)
      doctor_warn "Unsupported host OS for automatic virtualization check: $(uname -s)"
      ;;
  esac

  if command -v sbx >/dev/null 2>&1; then
    if sbx ls >/dev/null 2>&1; then
      doctor_ok "sbx daemon reachable and user appears logged in"
    else
      sbx_output="$(sbx ls 2>&1 || true)"
      case "$sbx_output" in
        *authentication*|*"not logged"*|*"login"*)
          doctor_fail "sbx authentication failed. Run: sbx login"
          ;;
        *daemon*|*"not reachable"*|*"connection refused"*|*"no such file"*)
          doctor_fail "sbx daemon is not reachable. Try: sbx setup, then sbx login"
          ;;
        *)
          doctor_fail "sbx is installed, but a basic sbx command failed: $sbx_output"
          ;;
      esac
    fi
  fi

  if [ "$DOCTOR_FAILS" -eq 0 ]; then
    if [ "$DOCTOR_WARNS" -eq 0 ]; then
      info "Doctor passed."
    else
      warn "Doctor passed with $DOCTOR_WARNS warning(s)."
    fi
    return 0
  fi

  warn "Doctor found $DOCTOR_FAILS problem(s). Run 'sbx diagnose' for deeper Docker Sandboxes diagnostics."
  return 1
}

completion_body() {
  cat <<'EOF'
_code_airlock() {
  local cur prev commands opts agents
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  commands="up run setup doctor status attach init shell fetch diff review merge pr net stop rm lockdown unlock completion help"
  opts="--agent --dry-run --tmux --tmux-detached --seed-config"
  agents="claude codex opencode gemini copilot cursor droid kiro shell"

  if [ "$prev" = "--agent" ]; then
    COMPREPLY=($(compgen -W "$agents" -- "$cur"))
    return
  fi
  case "$cur" in
    -*) COMPREPLY=($(compgen -W "$opts" -- "$cur")); return ;;
  esac
  case "$prev" in
    completion) COMPREPLY=($(compgen -W "bash zsh" -- "$cur")); return ;;
  esac
  COMPREPLY=($(compgen -W "$commands" -- "$cur"))
}
complete -F _code_airlock code-airlock codelock
EOF
}

cmd_completion() {
  shell="${1:-${SHELL##*/}}"
  case "$shell" in
    bash)
      completion_body
      ;;
    zsh)
      printf 'autoload -U +X compinit && compinit\n'
      printf 'autoload -U +X bashcompinit && bashcompinit\n'
      completion_body
      ;;
    *)
      die "Unsupported shell for completion: $shell (bash and zsh are supported)"
      ;;
  esac
}

usage() {
  cat <<EOF
code-airlock — run coding agents in a Docker Sandbox microVM

Usage: $(basename "$0") [--agent <name>] [--dry-run] [--tmux|--tmux-detached] [--seed-config] <command> [args]

  up [-- agent-args]  Create and start the sandbox (clone mode, agent-specific bypass mode)
  run "<task>"        Start the sandbox and hand the agent a task non-interactively
  setup               Guided install of missing prerequisites (asks before running anything)
  doctor              Check sbx, virtualization/KVM, git, daemon, and login status
  status              Show this repo's sandbox and tmux session status
  attach              Attach to this repo's Code Airlock tmux session
  shell               Open a shell inside the running sandbox
  fetch               Fetch sandbox commits, including initialized submodules
  diff  [base]        Fetch, then diff base..sandbox-<name>/base
  review [base]       Fetch, then open a visual git difftool review
  merge [base]        Fetch, then merge the agent's branch into base
  pr [base] [branch]  Fetch, push the sandbox branch to origin, and open a pull request
  net                 Show the sandbox network log (allowed / blocked hosts)
  stop                Stop the sandbox, keeping the VM and its commits
  rm                  Remove the sandbox and repo tmux session
  lockdown            Set deny-all default policy and allowlist an existing sandbox
  unlock              Reset Docker Sandboxes policies with: sbx policy reset
  init                Create a starter AGENTS.md in the target repo
  completion [shell]  Print bash or zsh completion (e.g. source <($(basename "$0") completion))
  help                Show this message

Options:
  --agent <name>      Select the agent: claude, codex, opencode, gemini, ... (overrides AGENT)
  --dry-run           Print commands without running them
  --tmux              Run 'up' inside a host tmux session and attach
  --tmux-detached     Run 'up' inside a detached host tmux session
  --seed-config       Copy curated user-level agent config before starting

Config: edit ./sandbox.conf (see sandbox.conf.example) or set env vars.
Active agent: $AGENT
Active sandbox name: $NAME
Active tmux session: $TMUX_SESSION
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --tmux)
      USE_TMUX=1
      TMUX_ATTACH=1
      shift
      ;;
    --tmux-detached)
      USE_TMUX=1
      TMUX_ATTACH=0
      shift
      ;;
    --seed-config|--seed-user-config)
      SEED_CONFIG=1
      SEED_USER_CONFIG=1
      shift
      ;;
    --agent)
      [ "$#" -ge 2 ] || die "--agent needs a value, e.g. --agent codex"
      AGENT="$2"
      shift 2
      ;;
    --agent=*)
      AGENT="${1#--agent=}"
      [ -n "$AGENT" ] || die "--agent needs a value, e.g. --agent=codex"
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

case "${1:-help}" in
  up)       shift; cmd_up "$@" ;;
  run)      shift; cmd_run "$@" ;;
  setup)    shift; cmd_setup "$@" ;;
  doctor)   shift; cmd_doctor "$@" ;;
  status)   shift; cmd_status "$@" ;;
  attach)   shift; cmd_attach "$@" ;;
  init)     shift; cmd_init "$@" ;;
  shell)    shift; cmd_shell "$@" ;;
  fetch)    shift; cmd_fetch "$@" ;;
  diff)     shift; cmd_diff "$@" ;;
  review)   shift; cmd_review "$@" ;;
  merge)    shift; cmd_merge "$@" ;;
  pr)       shift; cmd_pr "$@" ;;
  net)      shift; cmd_net "$@" ;;
  stop)     shift; cmd_stop "$@" ;;
  rm)       shift; cmd_rm "$@" ;;
  lockdown) shift; cmd_lockdown "$@" ;;
  unlock)   shift; cmd_unlock "$@" ;;
  completion) shift; cmd_completion "$@" ;;
  help|-h|--help) usage ;;
  *) err "Unknown command: $1"; echo; usage; exit 1 ;;
esac
